# OpenRouter API Configuration
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_api_key_here

# OpenRouter Base URL
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model to use (free models recommended for testing)
# Examples:
#   - xiaomi/mimo-v2-flash:free  (free, fast)
#   - google/gemini-flash-1.5-8b-exp-0827:free  (free, good quality)
#   - meta-llama/llama-3.2-3b-instruct:free  (free, small)
OPENROUTER_MODEL=xiaomi/mimo-v2-flash:free

# Optional: Your app name and URL for OpenRouter analytics
# OPENROUTER_APP_NAME=five-layer-coding-agent
# OPENROUTER_SITE_URL=https://github.com/your-repo

# Optional: Maximum concurrent requests
# OPENROUTER_MAX_CONCURRENT=4

# Optional: Request timeout in seconds
# OPENROUTER_TIMEOUT=30
